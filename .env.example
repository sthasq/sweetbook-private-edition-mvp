SWEETBOOK_ENABLED=true
# Optional: leave blank to use simulated Sweetbook responses in local/demo mode.
SWEETBOOK_API_KEY=
SWEETBOOK_BASE_URL=https://api-sandbox.sweetbook.com/v1
# Optional unless you are testing signed webhook delivery.
SWEETBOOK_WEBHOOK_SECRET=

MYSQL_ROOT_PASSWORD=playpick
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_BIND_HOST=0.0.0.0
MYSQL_HOST_PORT=3307
MYSQL_DATABASE=playpick
MYSQL_USERNAME=playpick
MYSQL_PASSWORD=playpick

REDIS_HOST=localhost
REDIS_BIND_HOST=0.0.0.0
REDIS_PORT=6380
BACKEND_BIND_HOST=0.0.0.0
BACKEND_HOST_PORT=8080
FRONTEND_BIND_HOST=0.0.0.0
FRONTEND_HOST_PORT=3000

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
APP_BASE_PATH=/
FRONTEND_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=
# Sweetbook live integration uses PUBLIC_BASE_URL first, then FRONTEND_BASE_URL.
PUBLIC_ASSET_BASE_URL=https://gscheon.com/playpick-assets
PUBLIC_ASSET_SCP_TARGET=
PUBLIC_ASSET_SSH_KEY_PATH=

# Optional: leave blank to use deterministic mock chat replies in local/demo mode.
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=google/gemini-3-flash-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

TOSS_PAYMENTS_ENABLED=false
# Optional: set all three values only when you want to test the Toss payment widget and payment confirmation flow.
# If left disabled or blank, the app falls back to the non-widget demo order flow.
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
